APP_NAME=PAV Detector
APP_ENV=dev
LOG_LEVEL=INFO

# Detection threshold for VPN/PROXY alerting
THRESHOLD=0.80

# Class order must match model output indexes
CLASSES=LEGIT,VPN,PROXY

# Optional explicit feature order.
# For stable inference, set this from models/feature_order.json generated by training.
FEATURE_ORDER=

# Model and preprocessing artifacts
MODEL_DIR=models
MODEL_ONNX_PATH=models/model.onnx
MODEL_TORCH_PATH=models/model.pt
SCALER_PATH=models/scaler.pkl

# CICFlowMeter command for offline mode (--pcap path)
CICFLOWMETER_CMD=cicflowmeter

# Database
ENABLE_DB=true
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/pav_detector
# Admin database to connect for CREATE DATABASE (usually postgres)
POSTGRES_ADMIN_DB=postgres

# Default sensor id
SENSOR_NAME=default-sensor
